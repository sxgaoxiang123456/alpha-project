# ============================================================
# A股自动盯盘AI助手 · 环境变量配置模板
# 复制为 .env 后填写实际值，敏感信息勿提交到版本控制
# Version: 2026-05-30
# ============================================================

# -----------------------------------------------------------
# 1. 飞书推送通道（主通道）— 必填
# -----------------------------------------------------------
# 企业自建应用凭证，用于调用飞书 Open API 发送推送卡片
# 获取方式：飞书开发者后台 → 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 接收推送的会话标识
# brand: 企业标识（如企业域名前缀）— 非飞书 API 标准必填项，lark-cli 可能需要，暂预留
# chat_id: 接收推送的群聊/用户会话 ID — 必填，飞书群设置中获取
FEISHU_BRAND=
FEISHU_CHAT_ID=

# -----------------------------------------------------------
# 2. Telegram 推送通道（备用通道，可选）
# -----------------------------------------------------------
# Telegram Bot Token，用于备用推送降级
# 获取方式：@BotFather 创建机器人
TELEGRAM_BOT_TOKEN=

# Telegram 代理配置（国内访问需要，可选）
# 格式：http://host:port 或 socks5://host:port
TELEGRAM_PROXY=

# -----------------------------------------------------------
# 3. 配置加密密钥（必须）
# -----------------------------------------------------------
# 用于加密存储敏感配置（app_secret、bot_token 等）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 或：python3 -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# 请务必保存此密钥，丢失后已加密配置无法解密
SETTINGS_ENCRYPTION_KEY=

# -----------------------------------------------------------
# 4. 数据源配置（默认值通常足够，按需调整）
# -----------------------------------------------------------
# 主数据源超时（秒）
DATASOURCE_PRIMARY_TIMEOUT=10
# 备用数据源超时（秒）
DATASOURCE_FALLBACK_TIMEOUT=15
# 数据源重试次数
DATASOURCE_RETRY_COUNT=2
# 健康检查间隔（秒，默认 5 分钟）
HEALTH_CHECK_INTERVAL=300

# -----------------------------------------------------------
# 5. 行情刷新配置（默认值通常足够，按需调整）
# -----------------------------------------------------------
# 行情定时刷新周期（秒，默认 3 分钟）
QUOTE_REFRESH_INTERVAL=180
# 行情缓存过期时间（秒，默认 5 分钟）
QUOTE_CACHE_TTL=300

# -----------------------------------------------------------
# 6. 系统配置
# -----------------------------------------------------------
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 数据库 URL（MVP 使用 SQLite，后续可迁移 PostgreSQL）
DATABASE_URL=sqlite:///./data/watchlist.db
